# Copy to infra/backup.env on the server and edit there.
# infra/backup.env is intentionally ignored by git.

# Compose file used by backup/restore scripts.
COMPOSE_FILE=compose-prod.yml

# Local directory for created archives before upload.
BACKUP_DIR=./backups

# Keep local backup archives for this many days. Remote Google Drive cleanup is manual.
BACKUP_RETENTION_DAYS=14

# Google Drive target configured through rclone.
# Example after `rclone config` creates a remote named `gdrive`:
BACKUP_RCLONE_REMOTE=gdrive:radiometer-backups
BACKUP_UPLOAD=1

# Optional: backup only selected MinIO buckets, separated by spaces.
# Empty value means all buckets.
S3_BACKUP_BUCKETS=

# Internal MinIO endpoint from inside the Docker network.
MINIO_INTERNAL_URL=http://minio:9000

# If compose project name is not the infra directory basename, set this or BACKUP_DOCKER_NETWORK.
# COMPOSE_PROJECT_NAME=infra
# BACKUP_DOCKER_NETWORK=infra_default

# Optional rclone tuning. Keep quoted if there are spaces.
# RCLONE_FLAGS="--drive-chunk-size 256M --transfers 1 --checkers 4"
